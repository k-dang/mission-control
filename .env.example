# This environment variable is used in Production and Preview environments to deploy your Convex project
# This variable is not needed in development.
# You can create a Production or Preview deploy key at https://dashboard.convex.dev/project/settings#production-deploy-keys
CONVEX_DEPLOY_KEY=

# Convex action webhook target for todo status transitions.
# Configure this as a Convex environment variable in your deployment:
# https://docs.convex.dev/production/environment-variables
DISCORD_WEBHOOK_URL=

# --- Convex environment variables (dashboard), not Next.js .env.local ---
# Vercel Sandbox (used by convex/sandbox.ts and convex/opencode.ts)
# VERCEL_TEAM_ID=
# VERCEL_PROJECT_ID=
# VERCEL_TOKEN=
# GITHUB_TOKEN=   # optional: pass into sandbox env at create time for authenticated git clone (e.g. private repos). Not used by opencode.ts.

# Vercel AI Gateway — required by convex/opencode.ts for egress credential brokering (key never stored in the VM)
# https://vercel.com/kb/guide/running-opencode-securely-with-the-vercel-sandbox
# AI_GATEWAY_API_KEY=
