# This environment variable is used in Production and Preview environments to deploy your Convex project
# This variable is not needed in development.
# You can create a Production or Preview deploy key at https://dashboard.convex.dev/project/settings#production-deploy-keys
CONVEX_DEPLOY_KEY=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk auth routing for the dedicated sign-in page.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Clerk x Convex auth
CLERK_FRONTEND_API_URL=

# Configure these environment variables as a Convex environment variable in your deployment:

# https://docs.convex.dev/production/environment-variables
DISCORD_WEBHOOK_URL=

# Vercel Sandbox
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
VERCEL_TOKEN=

# Vercel AI Gateway
AI_GATEWAY_API_KEY=

# Github token
GITHUB_TOKEN=
