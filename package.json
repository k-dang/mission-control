{
  "name": "mission-control",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "next dev -p 3001",
    "dev:backend": "convex dev",
    "predev": "convex dev --until-success",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint . --ignore-pattern \"convex/_generated/**\" --ignore-pattern \"opensrc/**\"",
    "typecheck": "tsc --noEmit && tsc --noEmit --project convex/tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.2.7",
    "@clerk/ui": "^1.6.7",
    "@opencode-ai/sdk": "^1.14.24",
    "@vercel/sandbox": "^1.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.37.0",
    "lucide-react": "^0.563.0",
    "next": "16.2.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.2.2",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@tailwindcss/oxide"
    ],
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
